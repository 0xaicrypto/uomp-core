{
  "name": "@uomp/server",
  "version": "0.0.1",
  "type": "module",
  "description": "UOMP combined Auth + Guard HTTP server",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "node --import ./node_modules/@uomp/server/dist/loader.js ./dist/index.js",
    "start": "node ./dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@uomp/core": "workspace:*",
    "@uomp/auth": "workspace:*",
    "@uomp/guard": "workspace:*",
    "@uomp/token": "workspace:*",
    "@hono/node-server": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  }
}
